        <tbody>
          <tr><td style="font-weight:600">newmember01</td><td style="font-size:12px;color:#888">new***@gmail.com</td><td>Miền Bắc</td><td><span class="badge-green">✅ Active</span></td><td style="font-size:12px;color:#888">23/04/2026</td></tr>
          <tr><td style="font-weight:600">caothu_test</td><td style="font-size:12px;color:#888">cao***@gmail.com</td><td>Miền Nam</td><td><span class="badge-gold">⏳ Chờ xác nhận</span></td><td style="font-size:12px;color:#888">22/04/2026</td></tr>
          <tr><td style="font-weight:600">xosohocsinh</td><td style="font-size:12px;color:#888">xos***@gmail.com</td><td>Miền Trung</td><td><span class="badge-green">✅ Active</span></td><td style="font-size:12px;color:#888">21/04/2026</td></tr>
