<style>
.chat-page{max-width:1000px;margin:12px auto;padding:0 14px;}
.chat-layout{display:grid;grid-template-columns:220px 1fr;gap:12px;height:calc(100vh - 190px);min-height:500px;}
.chat-rooms{background:#fff;border:1px solid var(--border);border-radius:4px;display:flex;flex-direction:column;overflow:hidden;}
.rooms-head{background:var(--red);color:#fff;padding:10px 12px;font-weight:700;font-size:13px;font-family:'Oswald',sans-serif;}
.room-list{overflow-y:auto;flex:1;}
.room-item{padding:9px 12px;border-bottom:1px solid #f0f0f0;cursor:pointer;transition:background .15s;}
.room-item:hover,.room-item.active{background:#fdecea;}
.room-name{font-weight:600;font-size:13px;color:#333;}
.room-item.active .room-name{color:var(--red);}
.room-online{font-size:11px;color:#aaa;}
.chat-main{background:#fff;border:1px solid var(--border);border-radius:4px;display:flex;flex-direction:column;overflow:hidden;}
.chat-main-head{background:var(--red);color:#fff;padding:10px 14px;font-weight:700;font-size:14px;font-family:'Oswald',sans-serif;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.chat-msgs{flex:1;overflow-y:auto;padding:12px;background:#fafafa;}
.chat-msgs::-webkit-scrollbar{width:5px;}
.chat-msgs::-webkit-scrollbar-thumb{background:#ddd;border-radius:5px;}
.msg{display:flex;gap:8px;margin-bottom:10px;}
.msg-ava{width:30px;height:30px;border-radius:50%;font-family:'Oswald',sans-serif;font-size:11px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--red);}
.msg-bubble{max-width:75%;}
.msg-meta{font-size:11px;color:#aaa;margin-bottom:2px;}
.msg-meta .un{color:var(--red);font-weight:700;margin-right:6px;}
.msg-text{background:#fff;border:1px solid #eee;border-radius:0 8px 8px 8px;padding:7px 10px;font-size:13px;color:#333;box-shadow:0 1px 2px rgba(0,0,0,.05);}
.msg.me .msg-text{background:#fdecea;border-color:#f5c6c0;border-radius:8px 0 8px 8px;}
.msg.me{flex-direction:row-reverse;}
.msg.me .msg-meta{text-align:right;}
.chat-input-area{padding:10px 12px;border-top:1px solid #eee;flex-shrink:0;}
.emoji-bar{display:flex;gap:5px;margin-bottom:6px;}
.em-btn{background:none;border:none;font-size:18px;cursor:pointer;transition:transform .1s;}
.em-btn:hover{transform:scale(1.3);}
.chat-input-row2{display:flex;gap:8px;}
.chat-text-inp{flex:1;padding:9px 14px;border:1px solid #ddd;border-radius:20px;font-size:13px;outline:none;font-family:inherit;}
.chat-text-inp:focus{border-color:var(--red);}
.chat-send-btn{background:var(--red);color:#fff;border:none;border-radius:50%;width:40px;height:40px;font-size:16px;cursor:pointer;}
</style>

<div class="chat-page">
  <div class="breadcrumb"><a href="/home">Trang chủ</a><span class="sep">›</span><span>Chat Live</span></div>
  <div class="chat-layout">
    <div class="chat-rooms">
      <div class="rooms-head">💬 Phòng Chat</div>
      <div class="room-list">
        <div class="room-item active" onclick="switchRoom(this,'nhap-mon')"><div class="room-name">🔥 Phòng Nhập Môn</div><div class="room-online" id="count-nhap-mon">-- online</div></div>
        <div class="room-item" onclick="switchRoom(this,'mien-bac')"><div class="room-name">🎯 Miền Bắc</div><div class="room-online" id="count-mien-bac">-- online</div></div>
        <div class="room-item" onclick="switchRoom(this,'mien-nam')"><div class="room-name">🌴 Miền Nam</div><div class="room-online" id="count-mien-nam">-- online</div></div>
        <div class="room-item" onclick="switchRoom(this,'mien-trung')"><div class="room-name">🌺 Miền Trung</div><div class="room-online" id="count-mien-trung">-- online</div></div>
        <div class="room-item" onclick="switchRoom(this,'vip')"><div class="room-name">👑 VIP Cao Thủ</div><div class="room-online" id="count-vip">-- online</div></div>
      </div>
    </div>
    <div class="chat-main">
      <div class="chat-main-head">
        <span id="roomTitle">🔥 Phòng Nhập Môn</span>
        <span style="font-size:12px;color:rgba(255,255,255,.7);" id="onlineCount">0 online</span>
      </div>
      <div class="chat-msgs" id="chatMsgs"></div>
      <div class="chat-input-area">
        <div class="emoji-bar">
          <button class="em-btn" onclick="addEmo('😀')">😀</button>
          <button class="em-btn" onclick="addEmo('🎯')">🎯</button>
          <button class="em-btn" onclick="addEmo('🏆')">🏆</button>
          <button class="em-btn" onclick="addEmo('💰')">💰</button>
          <button class="em-btn" onclick="addEmo('🔥')">🔥</button>
          <button class="em-btn" onclick="addEmo('👍')">👍</button>
        </div>
        <div class="chat-input-row2">
          <input type="text" class="chat-text-inp" id="liveInput" placeholder="Nhắn tin..." />
          <button class="chat-send-btn" onclick="sendMsg()">➤</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket   = io();
const ME       = '{{#if user}}{{user.username}}{{else}}Khách{{/if}}';
const USER_ID  = '{{#if user}}{{user.id}}{{else}}{{/if}}';
let   currentRoom = 'nhap-mon';

socket.emit('join', { username: ME, room: currentRoom });

socket.on('chat_message', (data) => {
  appendMsg(data.username, data.message, data.time, data.username === ME);
});

socket.on('online_count', (count) => {
  document.getElementById('onlineCount').textContent = count + ' online';
  const el = document.getElementById('count-' + currentRoom);
  if (el) el.textContent = count + ' online';
});

function appendMsg(username, message, time, isMe) {
  const box = document.getElementById('chatMsgs');
  const div = document.createElement('div');
  div.className = 'msg' + (isMe ? ' me' : '');
  const initials = username.substring(0,2).toUpperCase();
  div.innerHTML = `
    <div class="msg-ava" style="background:${isMe?'var(--blue)':'var(--red)'}">${initials}</div>
    <div class="msg-bubble">
      <div class="msg-meta"><span class="un">${username}</span><span>${time}</span></div>
      <div class="msg-text">${message.replace(/</g,'&lt;')}</div>
    </div>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function sendMsg() {
  const inp = document.getElementById('liveInput');
  const msg = inp.value.trim();
  if (!msg) return;
  socket.emit('chat_message', { message: msg, user_id: USER_ID });
  inp.value = '';
}

function switchRoom(el, room) {
  document.querySelectorAll('.room-item').forEach(r => r.classList.remove('active'));
  el.classList.add('active');
  socket.emit('leave_room', currentRoom);
  currentRoom = room;
  socket.emit('join', { username: ME, room });
  document.getElementById('chatMsgs').innerHTML = '';
  document.getElementById('roomTitle').textContent = el.querySelector('.room-name').textContent;
}

function addEmo(e) {
  document.getElementById('liveInput').value += e;
  document.getElementById('liveInput').focus();
}

document.getElementById('liveInput').addEventListener('keypress', e => {
  if (e.key === 'Enter') sendMsg();
});
</script>
