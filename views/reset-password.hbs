<div class="auth-topnav">
  <a class="brand" href="/home">DĐSH DIỄN ĐÀN</a>
  <a class="back" href="/login">← Đăng nhập</a>
</div>
<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="badge">🔑</div>
      <div class="title">Đặt Lại Mật Khẩu</div>
      <div class="sub">Nhập mật khẩu mới của bạn</div>
    </div>
    {{#if error}}<div class="alert alert-error">❌ {{error}}</div>{{/if}}
    <form action="/reset-password/{{token}}" method="POST">
      <div class="form-group">
        <label>Mật khẩu mới</label>
        <input type="password" name="password" placeholder="Ít nhất 6 ký tự" required>
      </div>
      <div class="form-group">
        <label>Xác nhận mật khẩu</label>
        <input type="password" name="confirm" placeholder="Nhập lại mật khẩu" required>
      </div>
      <button type="submit" class="btn-submit">🔑 Đặt Lại Mật Khẩu</button>
    </form>
  </div>
</div>
