<div class="breadcrumb"><span>🏠 Trang chủ</span></div>

<div class="announce" style="background:#fff9e6;border-bottom:1px solid #f7dc6f;padding:4px 0;margin-bottom:10px;">
  <div style="max-width:1200px;margin:0 auto;padding:0 14px;">
    <div style="font-size:13px;color:#c0392b;font-weight:600;padding:2px 0;">🎉 CHƠI VỚI CÒ HỘI LẦN NÀY MỚI 1200K LIÊN TẬY</div>
    <div style="font-size:13px;color:#c0392b;font-weight:600;padding:2px 0;">❇️ SỐ CHỐT CÙNG MC DIỄN ĐÀN 🔥 — THÔNG BÁO RA MẮT WEB LIVE MC ❇️</div>
  </div>
</div>

<!-- FEATURED: VIDEO + BXH SỰ KIỆN -->
<div class="card fade-up">
  <div class="card-head">📌 SỰ KIỆN NỔI BẬT <a href="/forum">Xem tất cả »</a></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;" class="featured-grid">
    <!-- Video -->
    <div style="background:#000;position:relative;cursor:pointer;min-height:200px;display:flex;align-items:center;justify-content:center;flex-direction:column;" onclick="window.open('https://youtube.com','_blank')">
      <div style="width:58px;height:58px;background:rgba(200,0,0,.85);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:10px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </div>
      <div style="color:#fff;font-size:13px;font-weight:600;padding:0 16px;text-align:center;">Diễn Đàn DDSH — Sự Kiện Tháng 4/2026</div>
      <div style="color:#888;font-size:11px;margin-top:4px;">Xem trên YouTube</div>
    </div>
    <!-- Chat mobile -->
    <div class="mobile-chat-box" style="border-top:2px solid var(--red);">
      <div style="background:var(--red);color:#fff;padding:6px 12px;font-size:12px;font-weight:700;">💬 CHAT TRỰC TIẾP <span style="float:right">LIVE</span></div>
      <div id="mobileChatBox" style="height:120px;max-height:120px;overflow-y:auto;padding:8px;background:#111;font-size:11px;"></div>
      <div style="display:flex;gap:6px;padding:6px;background:#1a1a1a;">
        <input id="mobileChatInput" type="text" placeholder="Nhắn tin..." style="flex:1;padding:6px 10px;border:none;border-radius:20px;font-size:12px;background:#333;color:#fff;outline:none;">
        <button onclick="sendMChat()" style="background:var(--red);color:#fff;border:none;border-radius:50%;width:30px;height:30px;cursor:pointer;">➤</button>
      </div>
    </div>
    <!-- Chat box bên phải -->
    <div style="display:flex;flex-direction:column;height:100%;min-height:350px;">
      <div style="background:var(--red);color:#fff;padding:8px 12px;font-size:13px;font-weight:700;display:flex;justify-content:space-between;">
        <span>💬 CHAT NHẬP MÔN</span><span style="font-size:11px;opacity:.8">LIVE</span>
      </div>
      <div id="homeChatBox" style="height:250px;max-height:250px;overflow-y:auto;padding:8px;background:#fafafa;font-size:12px;"></div>
      <div style="padding:6px;border-top:1px solid #eee;display:flex;gap:6px;">
        <input id="homeChatInput" type="text" placeholder="Nhắn tin..." style="flex:1;padding:7px 10px;border:1px solid #ddd;border-radius:20px;font-size:12px;outline:none;">
        <button onclick="sendHomeChat()" style="background:var(--red);color:#fff;border:none;border-radius:50%;width:34px;height:34px;cursor:pointer;">➤</button>
      </div>
    </div>
    <!-- BXH ẩn - chuyển xuống dưới -->
    <div style="display:none;" id="bxhData">
      <div style="font-size:13px;font-weight:700;color:#c0392b;border-left:3px solid #c0392b;padding-left:8px;margin-bottom:8px;line-height:1.5;">🎯 SỰ KIỆN DỰ ĐOÁN THÁNG 4/2026<br>GIẢI THƯỞNG <span style="color:#c0392b;font-size:15px;font-weight:800;">500.000 VNĐ</span></div>
      <div style="background:#f39c12;color:#fff;text-align:center;padding:5px;font-weight:700;font-size:12px;border-radius:3px 3px 0 0;">🏆 ĐỆ NHẤT CAO THỦ — T4/2026</div>
      <table style="width:100%;border-collapse:collapse;font-size:12px;">
        <thead><tr style="background:#fff9e6;"><th style="padding:5px 8px;font-weight:700;color:#555;border:1px solid #eee;">STT</th><th style="padding:5px 8px;font-weight:700;color:#555;border:1px solid #eee;text-align:left;">Cao Thủ</th><th style="padding:5px 8px;font-weight:700;color:#555;border:1px solid #eee;">Điểm</th></tr></thead>
        <tbody>
          {{#each bxh}}
          <tr><td style="padding:5px 8px;border:1px solid #eee;text-align:center;font-weight:800;color:#c0392b;">{{rank}}</td><td style="padding:5px 8px;border:1px solid #eee;"><a href="/profile/{{name}}" style="color:#2980b9;font-weight:600;">{{name}}</a></td><td style="padding:5px 8px;border:1px solid #eee;text-align:center;font-weight:700;color:#c0392b;">{{diem}}</td></tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- DANH MỤC DIỄN ĐÀN -->
<div class="card fade-up">
  <div class="card-head">📋 DANH MỤC DIỄN ĐÀN</div>
  <table style="width:100%;border-collapse:collapse;">
    <thead>
      <tr style="background:#f8f8f8;border-bottom:2px solid #eee;">
        <th style="padding:10px 14px;text-align:left;font-size:13px;color:#555;font-weight:700;">Chuyên mục</th>
        <th style="padding:10px 14px;text-align:center;font-size:13px;color:#555;font-weight:700;width:80px;">Bài viết</th>
        <th style="padding:10px 14px;text-align:left;font-size:13px;color:#555;font-weight:700;">Bài viết mới nhất</th>
      </tr>
    </thead>
    <tbody>
      {{#each cats}}
      <tr style="border-bottom:1px solid #f0f0f0;" onmouseover="this.style.background='#fafafa'" onmouseout="this.style.background=''">
        <td style="padding:10px 14px;">
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:42px;height:42px;background:var(--red);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">{{icon}}</div>
            <div>
              <a href="/forum?cat={{slug}}" style="font-weight:700;font-size:14px;color:#333;text-decoration:none;">{{name}}</a>
              <div style="font-size:11px;color:#aaa;margin-top:2px;">{{description}}</div>
            </div>
          </div>
        </td>
        <td style="padding:10px 14px;text-align:center;font-weight:700;color:var(--red);font-size:14px;">{{post_count}}</td>
        <td style="padding:10px 14px;font-size:12px;color:#888;">— chưa có bài —</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<!-- FORUM TABLE -->
<div class="card fade-up">
  <div class="card-head">📝 BÀI VIẾT MỚI NHẤT <a href="/forum">Tất cả »</a></div>
  <div style="padding:8px 10px;border-bottom:1px solid #eee;">
    <input type="text" style="width:100%;padding:7px 12px;border:1px solid #ddd;border-radius:4px;font-size:13px;outline:none;" placeholder="🔍 Tìm bài viết, cao thủ..." oninput="filterPosts(this.value)">
  </div>
  <table class="ftable" id="postTable">
    <thead>
      <tr><th style="width:48%">Chủ đề</th><th>Tạo bởi</th><th>Likes</th><th>Views</th><th>Trả lời</th><th>Bài cuối</th></tr>
    </thead>
    <tbody>
      {{#each baiViet}}
      <tr>
        <td>
          <span class="tag tag-{{tag}}">{{tagLabel}}</span>
          <a href="/post/{{id}}" class="post-title-link">{{title}}</a>
        </td>
        <td class="tc"><a href="/profile/{{author}}" class="author-a {{#if (eq author 'ADMIN')}}adm{{/if}}">{{author}}</a></td>
        <td class="tc"><span class="num">{{likes}}</span>👍</td>
        <td class="tc"><span class="num">{{views}}</span></td>
        <td class="tc"><span class="num">{{replies}}</span></td>
        <td class="tc" style="font-size:11px;white-space:nowrap;">{{time}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  <div class="pagi">
    <a class="cur" href="/home">1</a>
    <a href="/home?page=2">2</a>
    <a href="/home?page=3">3</a>
    <a href="/home?page=4">4</a>
    <span style="padding:4px 6px;color:#aaa">...</span>
    <a href="/home?page=20">20</a>
    <a href="/home?page=2">Sau »</a>
  </div>
</div>

<script>
function filterPosts(q) {
  const rows = document.querySelectorAll('#postTable tbody tr');
  rows.forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}
</script>

<script>
// Load chat history vào home chat box
window.addEventListener('load', function() {
  var box = document.getElementById('homeChatBox');
  if (!box) return;
  var history = [
    {{#each chatHistory}}
    {username:'{{username}}', message:'{{message}}'},
    {{/each}}
  ];
  history.forEach(function(m) {
    var div = document.createElement('div');
    div.style.cssText = 'margin-bottom:6px;padding:4px 6px;background:rgba(255,255,255,0.1);border-radius:4px;font-size:11px;color:#ddd;';
    div.innerHTML = '<span style="color:#ff6b6b;font-weight:700;">@' + m.username + '</span><br>' + m.message;
    box.appendChild(div);
  });
  box.scrollTop = box.scrollHeight;
});
</script>
<script>
window.addEventListener('load', function() {
  var box = document.getElementById('mobileChatBox');
  if (!box || typeof io === 'undefined') return;
  var s = io();
  s.emit('join', { username: '{{user.username}}' || 'Khách', room: 'nhap-mon' });
  s.on('chat_message', function(d) {
    var div = document.createElement('div');
    div.style.cssText = 'color:#ddd;margin-bottom:4px;font-size:11px;border-bottom:1px solid #222;padding-bottom:3px;';
    div.innerHTML = '<span style="color:#e74c3c;font-weight:700;">@' + d.username + '</span> ' + d.message;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  });
  window.sendMChat = function() {
    var inp = document.getElementById('mobileChatInput');
    if (inp && inp.value.trim()) {
      s.emit('chat_message', { message: inp.value.trim(), user_id: '{{user.id}}' });
      inp.value = '';
    }
  };
  document.getElementById('mobileChatInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') sendMChat();
  });
});
</script>
<script>
window.addEventListener('load', function() {
  if (typeof io === 'undefined') return;
  var s = io();
  s.emit('join', { username: '{{user.username}}' || 'Khách', room: 'nhap-mon' });
  
  function addMsg(username, message, time) {
    var box = document.getElementById('homeChatBox');
    if (!box) return;
    var div = document.createElement('div');
    div.style.cssText = 'margin-bottom:8px;padding:4px 6px;background:#fff;border-radius:4px;border-left:2px solid var(--red);font-size:12px;';
    div.innerHTML = '<span style="color:var(--red);font-weight:700;">@' + username + '</span> <span style="color:#aaa;font-size:10px;">' + time + '</span><br>' + message;
    box.appendChild(div);
    box.scrollTop = box.scrollHeight;
  }
  
  s.on('chat_message', function(d) { addMsg(d.username, d.message, d.time); });
  
  window.sendHomeChat = function() {
    var inp = document.getElementById('homeChatInput');
    if (inp && inp.value.trim()) {
      s.emit('chat_message', { message: inp.value.trim(), user_id: '{{user.id}}' });
      inp.value = '';
    }
  };
  
  var inp = document.getElementById('homeChatInput');
  if (inp) inp.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') sendHomeChat();
  });
  
  // Mobile chat cũng dùng cùng socket
  var minp = document.getElementById('mobileChatInput');
  if (minp) {
    s.on('chat_message', function(d) {
      var box2 = document.getElementById('mobileChatBox');
      if (!box2) return;
      var div = document.createElement('div');
      div.style.cssText = 'color:#ddd;margin-bottom:4px;font-size:11px;';
      div.innerHTML = '<span style="color:#e74c3c;font-weight:700;">@' + d.username + '</span> ' + d.message;
      box2.appendChild(div);
      box2.scrollTop = box2.scrollHeight;
    });
    window.sendMChat = function() {
      if (minp.value.trim()) {
        s.emit('chat_message', { message: minp.value.trim(), user_id: '{{user.id}}' });
        minp.value = '';
      }
    };
    minp.addEventListener('keypress', function(e) { if(e.key==='Enter') sendMChat(); });
  }
});
</script>
