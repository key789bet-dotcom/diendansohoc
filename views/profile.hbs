<style>
.prof-cover{height:150px;background:linear-gradient(135deg,#8e1a0e,#c0392b,#e74c3c);border-radius:4px 4px 0 0;position:relative;}
.prof-ava{position:absolute;bottom:-28px;left:20px;width:74px;height:74px;border-radius:50%;background:var(--red);border:4px solid #fff;display:flex;align-items:center;justify-content:center;font-family:'Oswald',sans-serif;font-size:22px;font-weight:700;color:#fff;}
.prof-info{background:#fff;border:1px solid var(--border);border-top:none;border-radius:0 0 4px 4px;padding:36px 18px 14px;margin-bottom:12px;}
.prof-name{font-family:'Oswald',sans-serif;font-size:20px;font-weight:700;}
.prof-badge{display:inline-block;background:var(--gold);color:#fff;font-size:11px;padding:2px 9px;border-radius:10px;font-weight:700;margin-left:8px;vertical-align:middle;}
.prof-meta{color:#888;font-size:12px;margin-top:4px;}
.prof-stats{display:flex;gap:20px;margin-top:10px;flex-wrap:wrap;}
.ps-item .n{font-size:18px;font-weight:800;color:var(--red);font-family:'Oswald',sans-serif;}
.ps-item .l{font-size:10px;color:#999;}
.tab-bar{display:flex;border-bottom:2px solid #eee;background:#fff;}
.tab-btn{padding:9px 16px;font-size:13px;font-weight:600;color:#666;cursor:pointer;border:none;background:none;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .15s;}
.tab-btn.active{color:var(--red);border-bottom-color:var(--red);}
.tab-pane{display:none;padding:10px 12px;}
.tab-pane.active{display:block;}
.prog-wrap{margin:6px 0;}
.prog-wrap .lbl{display:flex;justify-content:space-between;font-size:12px;color:#666;margin-bottom:3px;}
.prog-bar{height:8px;background:#eee;border-radius:4px;overflow:hidden;}
.prog-bar .fill{height:100%;background:var(--red);border-radius:4px;transition:width .5s;}
.award-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:8px;padding:8px 0;}
.award-item{border:1px solid #eee;border-radius:4px;padding:10px;text-align:center;}
.award-item.earned{border-color:var(--gold);background:#fff9e6;}
.award-item .ico{font-size:26px;margin-bottom:4px;}
.award-item .nm{font-size:11px;font-weight:700;color:#555;}
</style>

<div class="breadcrumb"><a href="/home">Trang chủ</a><span class="sep">›</span><span>Hồ sơ thành viên</span></div>

<div class="card fade-up" style="margin-bottom:12px;">
  <div class="prof-cover"><div class="prof-ava">M86</div></div>
  <div class="prof-info">
    <div><span class="prof-name">{{username}}</span><span class="prof-badge">⭐ Cao Thủ</span></div>
    <div class="prof-meta">📅 Tham gia: 15/03/2021 &nbsp;|&nbsp; 🌍 Miền Bắc &nbsp;|&nbsp; 📍 Online 30 phút trước</div>
    <div class="prof-stats">
      <div class="ps-item"><div class="n">2,341</div><div class="l">Bài viết</div></div>
      <div class="ps-item"><div class="n">847</div><div class="l">Điểm</div></div>
      <div class="ps-item"><div class="n">1,204</div><div class="l">Likes</div></div>
      <div class="ps-item"><div class="n">73%</div><div class="l">Tỉ lệ trúng</div></div>
    </div>
    <div style="margin-top:10px;display:flex;gap:8px;">
      <button class="btn btn-red btn-sm" onclick="this.textContent=this.textContent.includes('+')?'✓ Đang theo dõi':'+ Theo dõi'">+ Theo dõi</button>
      <button class="btn btn-sm" style="background:#f0f0f0;color:#555;border:1px solid #ddd;">✉️ Nhắn tin</button>
    </div>
  </div>
</div>

<div class="card fade-up">
  <div class="tab-bar tab-group">
    <button class="tab-btn active" data-tab="pane-posts">📝 Bài viết (2,341)</button>
    <button class="tab-btn" data-tab="pane-awards">🏅 Thành tích</button>
    <button class="tab-btn" data-tab="pane-stats">📊 Thống kê</button>
    <button class="tab-btn" data-tab="pane-follow">👥 Theo dõi</button>
  </div>
  <div id="pane-posts" class="tab-pane active">
    <table class="ftable">
      <thead><tr><th>Bài viết</th><th>Likes</th><th>Views</th><th>Ngày</th></tr></thead>
      <tbody>
        <tr><td><span class="tag tag-tl">Thảo luận</span><a href="/post/1" class="post-title-link">CÁI BANG THỐNG NHẤT THIÊN HA 2,3,4D - T4/2026</a></td><td class="tc">53 👍</td><td class="tc">84K</td><td class="tc" style="font-size:12px">23/04</td></tr>
        <tr><td><span class="tag tag-mb">Cầu MB</span><a href="/post/2" class="post-title-link">CẦU LÔ MB 22/04 — CHỐT ĐÔI THAY</a></td><td class="tc">41 👍</td><td class="tc">12K</td><td class="tc" style="font-size:12px">22/04</td></tr>
        <tr><td><span class="tag tag-tl">Thảo luận</span><a href="/post/3" class="post-title-link">BỘNG ĐÊ 3 NGÀY ĐẦU THÁNG 4 — KẾT QUẢ</a></td><td class="tc">38 👍</td><td class="tc">9.2K</td><td class="tc" style="font-size:12px">20/04</td></tr>
      </tbody>
    </table>
    <div class="pagi"><a class="cur" href="#">1</a><a href="#">2</a><a href="#">3</a><a href="#">Sau »</a></div>
  </div>
  <div id="pane-awards" class="tab-pane">
    <div class="award-grid">
      <div class="award-item earned"><div class="ico">🥇</div><div class="nm">Top 1 T3/2026</div></div>
      <div class="award-item earned"><div class="ico">🔥</div><div class="nm">Chuỗi 7 ngày</div></div>
      <div class="award-item earned"><div class="ico">🎯</div><div class="nm">Trúng 100 lần</div></div>
      <div class="award-item earned"><div class="ico">⭐</div><div class="nm">VIP Member</div></div>
      <div class="award-item"><div class="ico">👑</div><div class="nm">Huyền Thoại</div></div>
      <div class="award-item"><div class="ico">💎</div><div class="nm">Kim Cương</div></div>
    </div>
  </div>
  <div id="pane-stats" class="tab-pane">
    <h4 style="font-size:14px;font-weight:700;color:var(--red);margin-bottom:12px;">📊 Thống kê dự đoán T4/2026</h4>
    <div class="prog-wrap"><div class="lbl"><span>Tỉ lệ trúng tổng</span><span style="font-weight:700;color:var(--red)">73%</span></div><div class="prog-bar"><div class="fill" style="width:73%"></div></div></div>
    <div class="prog-wrap"><div class="lbl"><span>Trúng Lô đề</span><span>68%</span></div><div class="prog-bar"><div class="fill" style="width:68%;background:var(--green)"></div></div></div>
    <div class="prog-wrap"><div class="lbl"><span>Trúng Ba càng</span><span>28%</span></div><div class="prog-bar"><div class="fill" style="width:28%;background:var(--blue)"></div></div></div>
    <div class="prog-wrap"><div class="lbl"><span>Trúng Đặc biệt</span><span>12%</span></div><div class="prog-bar"><div class="fill" style="width:12%;background:var(--gold)"></div></div></div>
  </div>
  <div id="pane-follow" class="tab-pane">
    <div style="text-align:center;padding:20px;color:#888;font-size:13px;">Đăng nhập để xem danh sách theo dõi</div>
  </div>
</div>

<!-- THỐNG KÊ CÁ NHÂN -->
<div class="card fade-up">
  <div class="card-head">📊 THỐNG KÊ DỰ ĐOÁN</div>
  <div style="padding:16px;">
    <!-- Tổng quan -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;">
      <div style="text-align:center;padding:14px;background:#fdecea;border-radius:6px;">
        <div style="font-size:24px;font-weight:800;color:var(--red);font-family:'Oswald',sans-serif;">{{stats.tong_du_doan}}</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Tổng dự đoán</div>
      </div>
      <div style="text-align:center;padding:14px;background:#e8f5e9;border-radius:6px;">
        <div style="font-size:24px;font-weight:800;color:#27ae60;font-family:'Oswald',sans-serif;">{{stats.so_trung}}</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Số lần trúng</div>
      </div>
      <div style="text-align:center;padding:14px;background:#fff9e6;border-radius:6px;">
        <div style="font-size:24px;font-weight:800;color:#f39c12;font-family:'Oswald',sans-serif;">{{stats.ty_le}}%</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Tỉ lệ trúng</div>
      </div>
      <div style="text-align:center;padding:14px;background:#e8f4fd;border-radius:6px;">
        <div style="font-size:24px;font-weight:800;color:#2980b9;font-family:'Oswald',sans-serif;">{{#if bxhThang}}#{{bxhThang.hang}}{{else}}—{{/if}}</div>
        <div style="font-size:11px;color:#888;margin-top:2px;">Hạng tháng này</div>
      </div>
    </div>

    <!-- Thanh tỉ lệ -->
    <div style="margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;font-size:12px;color:#666;margin-bottom:4px;">
        <span>Tỉ lệ trúng tổng thể</span>
        <span style="font-weight:700;color:var(--red);">{{stats.ty_le}}%</span>
      </div>
      <div style="height:10px;background:#eee;border-radius:5px;overflow:hidden;">
        <div style="height:100%;background:linear-gradient(90deg,#c0392b,#e74c3c);border-radius:5px;width:{{stats.ty_le}}%;transition:width 1s;"></div>
      </div>
    </div>

    <!-- Thống kê theo loại -->
    {{#if predByType.length}}
    <div style="margin-bottom:16px;">
      <div style="font-size:13px;font-weight:700;color:#444;margin-bottom:8px;">Theo loại dự đoán:</div>
      {{#each predByType}}
      <div style="margin-bottom:8px;">
        <div style="display:flex;justify-content:space-between;font-size:12px;color:#666;margin-bottom:3px;">
          <span>{{loai}} ({{tong}} lần)</span>
          <span style="font-weight:700;">{{trung}}/{{tong}} trúng</span>
        </div>
        <div style="height:7px;background:#eee;border-radius:4px;overflow:hidden;">
          <div style="height:100%;background:var(--red);border-radius:4px;width:{{trung}}%;"></div>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}

    <!-- Biểu đồ 7 ngày -->
    <div>
      <div style="font-size:13px;font-weight:700;color:#444;margin-bottom:8px;">Lịch sử 7 ngày qua:</div>
      <canvas id="chartPred" height="80"></canvas>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@3/dist/chart.min.js"></script>
<script>
const predHistory = {{{predHistory}}};
if (predHistory.length) {
  const ctx = document.getElementById('chartPred').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: predHistory.map(d => d.ngay),
      datasets: [
        { label: 'Tổng', data: predHistory.map(d => d.tong), backgroundColor: '#eee' },
        { label: 'Trúng', data: predHistory.map(d => d.trung), backgroundColor: '#c0392b' }
      ]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
  });
}
</script>
