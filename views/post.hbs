<style>
.post-box{background:#fff;border:1px solid var(--border);border-radius:4px;margin-bottom:10px;}
.post-hd{padding:8px 14px;background:#f8f8f8;border-bottom:1px solid #eee;display:flex;align-items:center;gap:8px;font-size:12px;color:#888;}
.post-body{display:grid;grid-template-columns:120px 1fr;}
.post-user{padding:14px 10px;border-right:1px solid #eee;text-align:center;}
.ava{width:52px;height:52px;border-radius:50%;background:var(--red);color:#fff;font-family:'Oswald',sans-serif;font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 6px;}
.uname a{font-weight:700;font-size:13px;color:var(--red);}
.urank{font-size:11px;color:#888;margin:2px 0;}
.ubadge{font-size:11px;padding:1px 6px;border-radius:8px;background:#fdecea;color:var(--red);font-weight:700;margin:2px 0;}
.ustats{font-size:10px;color:#aaa;margin-top:4px;line-height:1.6;}
.post-content{padding:14px;font-size:14px;line-height:1.8;color:#333;}
.post-acts{padding:9px 14px;border-top:1px solid #eee;background:#fafafa;display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.act-btn{background:none;border:1px solid #ddd;border-radius:4px;padding:4px 12px;font-size:12px;cursor:pointer;color:#555;}
.act-btn:hover{background:#fdecea;border-color:var(--red);color:var(--red);}
.reply-box{background:#f5f5f5;border-left:3px solid var(--red);margin:0 14px 10px 130px;padding:10px;border-radius:0 4px 4px 0;}
.reply-form-box{display:none;background:#fff9e6;border-left:3px solid #f39c12;margin:0 14px 10px 130px;padding:10px;border-radius:0 4px 4px 0;}
.num-tag{background:#c0392b;color:#fff;font-weight:800;padding:1px 5px;border-radius:3px;font-size:12px;}
</style>

<div class="breadcrumb">
  <a href="/home">Trang chủ</a><span class="sep">›</span>
  <a href="/forum">Diễn đàn</a><span class="sep">›</span>
  <span>{{post.title}}</span>
</div>

<!-- BÀI VIẾT CHÍNH -->
<div class="post-box fade-up">
  <div class="post-hd">
    <span class="tag-badge {{post.tag}}">{{post.tagLabel}}</span>
    <span>{{post.title}}</span>
    <span style="margin-left:auto;">👁 {{post.views}} lượt xem</span>
  </div>
  <div class="post-body">
    <div class="post-user">
      {{#if post.avatar}}
      <img src="{{post.avatar}}" class="ava" style="object-fit:cover;">
      {{else}}
      <div class="ava">{{post.author.[0]}}</div>
      {{/if}}
      <div class="uname"><a href="/profile/{{post.author}}">{{post.author}}</a></div>
      <div class="urank">{{post.user_rank}}</div>
    </div>
    <div class="post-content">{{{post.content}}}</div>
  </div>
  <div class="post-acts">
    <button class="act-btn" onclick="likePost(this,{{post.id}})">👍 Thích <span id="likeNum">{{post.likes}}</span></button>
    <button class="act-btn">🔖 Lưu</button>
    <button class="act-btn">⚠️ Báo cáo</button>
    <span style="margin-left:auto;font-size:11px;color:#aaa;">👁 {{post.views}} lượt xem</span>
  </div>
</div>

<!-- BÌNH LUẬN -->
<div class="card fade-up">
  <div class="card-head">💬 BÌNH LUẬN ({{comments.length}})</div>

  {{#each comments}}
  {{#unless parent_id}}
  <div class="post-box" id="comment-{{id}}" style="margin:8px;border-radius:4px;">
    <div class="post-hd">#{{@index}} — {{username}} — {{created_at}}</div>
    <div class="post-body">
      <div class="post-user">
        {{#if avatar}}
        <img src="{{avatar}}" class="ava" style="object-fit:cover;">
        {{else}}
        <div class="ava" style="width:40px;height:40px;font-size:14px;">{{username.[0]}}</div>
        {{/if}}
        <div class="uname"><a href="/profile/{{username}}">{{username}}</a></div>
      </div>
      <div class="post-content" style="padding:10px;">{{content}}</div>
    </div>
    <div class="post-acts">
      <button class="act-btn" onclick="this.classList.toggle('liked')">👍 {{likes}}</button>
      {{#if ../user}}
      <button class="act-btn" onclick="showReply({{id}},'{{username}}')">💬 Trả lời</button>
      {{/if}}
    </div>

    <!-- Form reply -->
    <div id="reply-{{id}}" class="reply-form-box">
      <div style="font-size:12px;color:#888;margin-bottom:6px;">↩️ Trả lời <strong>@{{username}}</strong></div>
      <form action="/post/{{../post.id}}/reply/{{id}}" method="POST">
        <textarea name="content" rows="2" required
          style="width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;font-size:13px;resize:none;outline:none;font-family:inherit;"></textarea>
        <div style="display:flex;gap:6px;margin-top:6px;">
          <button type="submit" class="btn btn-red" style="font-size:12px;padding:5px 14px;">Gửi</button>
          <button type="button" onclick="hideReply({{id}})" style="font-size:12px;padding:5px 12px;border:1px solid #ddd;border-radius:4px;background:#fff;cursor:pointer;">Hủy</button>
        </div>
      </form>
    </div>

    <!-- Replies lồng nhau -->
    {{#each ../comments}}
    {{#if parent_id}}
    {{#if (eq parent_id ../id)}}
    <div class="reply-box">
      <div style="font-size:11px;color:#888;margin-bottom:4px;">↩️ <a href="/profile/{{username}}" style="color:var(--red);font-weight:700;">{{username}}</a> trả lời</div>
      <div style="font-size:13px;color:#333;">{{content}}</div>
    </div>
    {{/if}}
    {{/if}}
    {{/each}}
  </div>
  {{/unless}}
  {{/each}}
</div>

<!-- FORM BÌNH LUẬN MỚI -->
{{#if user}}
<div class="card fade-up">
  <div class="card-head">✍️ VIẾT BÌNH LUẬN</div>
  <div style="padding:14px;">
    <form action="/post/{{post.id}}/comment" method="POST">
      <textarea name="content" rows="4" required placeholder="Chia sẻ nhận định, kết quả..."
        style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;font-size:13px;resize:vertical;outline:none;font-family:inherit;"></textarea>
      <div style="margin-top:8px;text-align:right;">
        <button type="submit" class="btn btn-red">💬 Gửi bình luận</button>
      </div>
    </form>
  </div>
</div>
{{else}}
<div class="card" style="padding:16px;text-align:center;color:#888;">
  <a href="/login" style="color:var(--red);font-weight:700;">Đăng nhập</a> để bình luận
</div>
{{/if}}

<script>
function showReply(id, username) {
  document.querySelectorAll('.reply-form-box').forEach(f => f.style.display='none');
  const f = document.getElementById('reply-' + id);
  if (f) { f.style.display='block'; f.querySelector('textarea').focus(); }
}
function hideReply(id) {
  const f = document.getElementById('reply-' + id);
  if (f) f.style.display='none';
}
async function likePost(btn, postId) {
  const res = await fetch('/post/' + postId + '/like', { method: 'POST' });
  const data = await res.json();
  if (data.error) { alert('Vui lòng đăng nhập để like!'); return; }
  document.getElementById('likeNum').textContent = data.likes;
  btn.classList.add('liked');
}
</script>
