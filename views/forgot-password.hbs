<div class="auth-topnav">
  <a class="brand" href="/home">GMSH DIỄN ĐÀN</a>
  <a class="back" href="/login">← Đăng nhập</a>
</div>
<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="badge">🔐</div>
      <div class="title">Quên Mật Khẩu</div>
      <div class="sub">Nhập email để nhận link đặt lại mật khẩu</div>
    </div>
    {{#if error}}<div class="alert alert-error">❌ {{error}}</div>{{/if}}
    {{#if success}}<div class="alert alert-success">{{success}}</div>{{/if}}
    <form action="/forgot-password" method="POST">
      <div class="form-group">
        <label>Email đã đăng ký</label>
        <input type="email" name="email" placeholder="email@gmail.com" required>
      </div>
      <button type="submit" class="btn-submit">📧 Gửi Link Đặt Lại</button>
    </form>
    <div class="auth-switch">
      Nhớ mật khẩu rồi? <a href="/login">Đăng nhập</a>
    </div>
  </div>
</div>
