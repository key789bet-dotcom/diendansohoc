<div class="auth-topnav">
  <a class="brand" href="/home">GMSH DIỄN ĐÀN</a>
  <a class="back" href="/home">← Về trang chủ</a>
</div>
<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="badge">GMSH</div>
      <div class="title">Đăng Nhập</div>
      <div class="sub">Chào mừng trở lại diễn đàn GMSH</div>
    </div>
    <div id="alertBox"></div>
    <form action="/login" method="POST" onsubmit="return validateLogin()">
      <div class="form-group">
        <label>Tên đăng nhập / Email</label>
        <input type="text" name="username" placeholder="Nhập tên đăng nhập..." required>
      </div>
      <div class="form-group">
        <label>Mật khẩu</label>
        <input type="password" name="password" placeholder="Nhập mật khẩu..." required>
      </div>
      <div class="form-opts">
        <label><input type="checkbox" name="remember"> Ghi nhớ đăng nhập</label>
        <a href="#">Quên mật khẩu?</a>
      </div>
      <button type="submit" class="btn-submit">Đăng Nhập</button>
    </form>
    <div class="auth-divider">hoặc đăng nhập bằng</div>
    <div class="social-btns">
      <div class="social-btn">🔵 Facebook</div>
      <div class="social-btn">🔴 Google</div>
    </div>
    <div class="auth-switch">
      Chưa có tài khoản? <a href="/register">Đăng ký ngay</a>
    </div>
  </div>
</div>
<script>
function validateLogin() {
  const box = document.getElementById('alertBox');
  box.innerHTML = '<div class="alert alert-info">🔄 Đang xử lý...</div>';
  return true;
}
</script>
