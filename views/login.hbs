<div class="auth-topnav">
  <a class="brand" href="/home">DĐSH DIỄN ĐÀN</a>
  <a class="back" href="/home">← Về trang chủ</a>
</div>
<div class="auth-wrap">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="badge">DĐSH</div>
      <div class="title">Đăng Nhập</div>
      <div class="sub">Chào mừng trở lại diễn đàn DĐSH</div>
    </div>
    <div id="alertBox"></div>
    <form action="/login" method="POST" >
      <div class="form-group">
        <label>Tên đăng nhập / Email</label>
        <input type="text" name="username" placeholder="Nhập tên đăng nhập..." required>
      </div>
      <div class="form-group">
        <label>Mật khẩu</label>
        <input type="password" name="password" placeholder="Nhập mật khẩu..." required>
      </div>
      <div class="form-opts">
        <label><input type="checkbox" name="remember"> Ghi nhớ đăng nhập</label>
        <a href="/forgot-password">Quên mật khẩu?</a>
      </div>
      <button type="submit" class="btn-submit">Đăng Nhập</button>
    </form>
<div style="margin:16px 0;text-align:center;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
    <hr style="flex:1;border:none;border-top:1px solid #eee;">
    <span style="color:#aaa;font-size:12px;">HOẶC</span>
    <hr style="flex:1;border:none;border-top:1px solid #eee;">
  </div>
  <a href="/auth/google" style="display:flex;align-items:center;justify-content:center;gap:10px;padding:10px 20px;border:1px solid #ddd;border-radius:4px;text-decoration:none;color:#333;font-weight:600;font-size:14px;background:#fff;transition:all .2s;">
    <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
    Đăng nhập bằng Google
  </a>
</div>

    <div class="auth-divider">hoặc đăng nhập bằng</div>
    <div class="social-btns">
      <div class="social-btn">🔵 Facebook</div>
      <div class="social-btn">🔴 Google</div>
    </div>
    <div class="auth-switch">
      Chưa có tài khoản? <a href="/register">Đăng ký ngay</a>
    </div>
  </div>
</div>
<script>
function validateLogin() {
  const box = document.getElementById('alertBox');
  box.innerHTML = '<div class="alert alert-info">🔄 Đang xử lý...</div>';
  return true;
}
</script>
